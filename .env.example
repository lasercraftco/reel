# Reel configuration — copy to .env and fill in.
# Most secrets are already present in ~/homelab/.env on iMac. The deploy
# script (deploy/bootstrap.sh) symlinks them through.

# --- Brand ---
REEL_PUBLIC_NAME=Reel
REEL_TAGLINE=Self-hosted movie discovery
NEXT_PUBLIC_REEL_NAME=Reel
NEXT_PUBLIC_REEL_TAGLINE=Self-hosted movie discovery
NEXT_PUBLIC_REEL_DOMAIN=reel.tyflix.net

# --- Postgres ---
DATABASE_URL=postgres://reel:reel@postgres:5432/reel
POSTGRES_USER=reel
POSTGRES_PASSWORD=reel-local-dev
POSTGRES_DB=reel

# --- Engine ---
REEL_ENGINE_URL=http://reel-engine:8002
REEL_ENGINE_INTERNAL_URL=http://localhost:8002

# --- Discovery sources ---
TMDB_API_KEY=
TMDB_READ_TOKEN=
OMDB_API_KEY=
TRAKT_CLIENT_ID=
TRAKT_CLIENT_SECRET=
TRAKT_ACCESS_TOKEN=
LETTERBOXD_USER=
ANTHROPIC_API_KEY=

# --- Library wire ---
RADARR_URL=http://host.docker.internal:7878
RADARR_API_KEY=
PLEX_URL=http://host.docker.internal:32400
PLEX_TOKEN=
PLEX_MACHINE_ID=

# --- Tuning defaults (overridable per-mode) ---
REEL_DEFAULT_CONTENT_WEIGHT=0.18
REEL_DEFAULT_PLOT_WEIGHT=0.10
REEL_DEFAULT_COLLAB_WEIGHT=0.14
REEL_DEFAULT_LETTERBOXD_WEIGHT=0.14
REEL_DEFAULT_TMDB_SIMILAR_WEIGHT=0.10
REEL_DEFAULT_CREW_WEIGHT=0.10
REEL_DEFAULT_CRITIC_WEIGHT=0.06
REEL_DEFAULT_AWARDS_WEIGHT=0.04
REEL_DEFAULT_REDDIT_WEIGHT=0.04
REEL_DEFAULT_LLM_WEIGHT=0.05
REEL_DEFAULT_ITEM2VEC_WEIGHT=0.05
REEL_EXPLORATION_RATIO=0.08
REEL_CANDIDATE_POOL_SIZE=400

# --- Auth / SSO (shared across Reel + Genome + Karaoke) ---
# Generate with: openssl rand -hex 64. The SAME value should be set in every
# tyflix-family app's .env so JWTs are interchangeable.
TYFLIX_AUTH_JWT_SECRET=change-me-to-a-random-64-byte-hex
TYFLIX_AUTH_JWT_ISSUER=tyflix.net
TYFLIX_AUTH_COOKIE_NAME=tyflix_auth
TYFLIX_AUTH_COOKIE_DOMAIN=.tyflix.net
TYFLIX_AUTH_TOKEN_TTL_SECONDS=2592000
# Owner email — auto-promoted to role=owner on first sign-in.
TYFLIX_OWNER_EMAIL=tylerheon@gmail.com
# Magic-link mailer (re-uses ~/homelab/.env values where possible)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Reel <noreply@tyflix.net>"
# Public base URL for magic-link callbacks
REEL_PUBLIC_URL=https://reel.tyflix.net

# --- Per-user defaults ---
REEL_FRIEND_DAILY_REQUEST_QUOTA=5
REEL_FRIEND_AUTO_APPROVE=false

# --- Cache ---
TMDB_CACHE_TTL_SECONDS=86400
LETTERBOXD_SCRAPE_DELAY_MS=750
HTTP_USER_AGENT=Reel/1.0 (reel.tyflix.net)

# --- Logging ---
LOG_LEVEL=info
